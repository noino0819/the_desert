{
  "npcId": "villager_1",
  "lines": [
    {
      "lineId": "water_quest_hint",
      "speaker": "주민_할머니",
      "portrait": "villager_grandma",
      "text": "물이 없어서 큰일이에요, 젊은이.\n사막하마가 있을 땐 참 좋았는데…",
      "isNG": false,
      "condition": { "questId": "ch1_water", "state": "Active" },
      "choices": null
    },
    {
      "lineId": "water_quest_hint2",
      "speaker": "주민_할머니",
      "portrait": "villager_grandma",
      "text": "하마한테 뭔가 먹이면 움직이려나.\n그 녀석들, 진흙을 엄청 좋아하거든요.",
      "isNG": false,
      "condition": { "questId": "ch1_water", "state": "Active" },
      "choices": null
    },
    {
      "lineId": "mudcookie_delivery",
      "speaker": "주민_할머니",
      "portrait": "villager_grandma_tearful",
      "text": "어머, 이 냄새는...\n진흙쿠키잖아. 오래됐다, 오래됐어.\n고마워요, 젊은이.",
      "isNG": false,
      "condition": { "questId": "ch1_mudcookie", "state": "Active" },
      "choices": null
    }
  ]
}
