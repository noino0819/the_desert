{
  "npcId": "villager_3",
  "lines": [
    {
      "lineId": "mudcookie_delivery",
      "speaker": "주민_꼬마",
      "portrait": "villager_kid",
      "text": "와! 진흙쿠키다!\n엄마! 진흙쿠키 왔어!",
      "isNG": false,
      "condition": { "questId": "ch1_mudcookie", "state": "Active" },
      "choices": null
    },
    {
      "lineId": "scarf_ask",
      "speaker": "주민_꼬마",
      "portrait": "villager_kid",
      "text": "저기요, 아저씨!\n혹시… 그 스카프, 어디서 났어요?",
      "isNG": false,
      "condition": null,
      "choices": [
        {
          "text": "스카프를 보여준다.",
          "nextLineId": "scarf_show",
          "flagToSet": "",
          "questToProgress": "",
          "condition": null
        },
        {
          "text": "그냥 사막에서 주웠어.",
          "nextLineId": "scarf_dismiss",
          "flagToSet": "",
          "questToProgress": "",
          "condition": null
        }
      ]
    },
    {
      "lineId": "scarf_show",
      "speaker": "주민_꼬마",
      "portrait": "villager_kid_wide_eyes",
      "text": "이거… 우리 엄마 거예요.\n잼잼크래프트한테 전해달라고 했을 거예요. 저희 오빠.\n엄마가 사막 나갔다가 잃어버렸는데…",
      "isNG": false,
      "condition": null,
      "choices": [
        {
          "text": "스카프를 건네준다.",
          "nextLineId": "scarf_give",
          "flagToSet": "scarfGiven",
          "questToProgress": "",
          "condition": null
        },
        {
          "text": "가지고 있겠다.",
          "nextLineId": "scarf_keep",
          "flagToSet": "",
          "questToProgress": "",
          "condition": null
        }
      ]
    },
    {
      "lineId": "scarf_give",
      "speaker": "주민_꼬마",
      "portrait": "villager_kid_quiet",
      "text": "고마워요.",
      "isNG": false,
      "condition": null,
      "choices": null
    },
    {
      "lineId": "scarf_keep",
      "speaker": "주민_꼬마",
      "portrait": "villager_kid",
      "text": "...",
      "isNG": false,
      "condition": null,
      "choices": null
    },
    {
      "lineId": "scarf_dismiss",
      "speaker": "주민_꼬마",
      "portrait": "villager_kid",
      "text": "아... 그래요.",
      "isNG": false,
      "condition": null,
      "choices": null
    }
  ]
}
